FROM ghcr.io/cirruslabs/flutter:stable AS builder

WORKDIR /app

COPY pubspec.* ./
RUN flutter pub get

COPY . .

ARG INGAME_API_BASE_URL=
ARG INGAME_WEB_APP_BASE_URL=
ARG INGAME_INVITE_BASE_URL=
ARG DISCORD_CLIENT_ID=
ARG APPLE_SERVICE_ID=
ARG FIREBASE_WEB_API_KEY=
ARG FIREBASE_WEB_AUTH_DOMAIN=
ARG FIREBASE_WEB_PROJECT_ID=
ARG FIREBASE_WEB_STORAGE_BUCKET=
ARG FIREBASE_WEB_MESSAGING_SENDER_ID=
ARG FIREBASE_WEB_APP_ID=
ARG FIREBASE_WEB_VAPID_KEY=

RUN flutter build web --release \
    --dart-define=INGAME_API_BASE_URL=${INGAME_API_BASE_URL} \
    --dart-define=INGAME_WEB_APP_BASE_URL=${INGAME_WEB_APP_BASE_URL} \
    --dart-define=INGAME_INVITE_BASE_URL=${INGAME_INVITE_BASE_URL} \
    --dart-define=DISCORD_CLIENT_ID=${DISCORD_CLIENT_ID} \
    --dart-define=APPLE_SERVICE_ID=${APPLE_SERVICE_ID} \
    --dart-define=FIREBASE_WEB_API_KEY=${FIREBASE_WEB_API_KEY} \
    --dart-define=FIREBASE_WEB_AUTH_DOMAIN=${FIREBASE_WEB_AUTH_DOMAIN} \
    --dart-define=FIREBASE_WEB_PROJECT_ID=${FIREBASE_WEB_PROJECT_ID} \
    --dart-define=FIREBASE_WEB_STORAGE_BUCKET=${FIREBASE_WEB_STORAGE_BUCKET} \
    --dart-define=FIREBASE_WEB_MESSAGING_SENDER_ID=${FIREBASE_WEB_MESSAGING_SENDER_ID} \
    --dart-define=FIREBASE_WEB_APP_ID=${FIREBASE_WEB_APP_ID} \
    --dart-define=FIREBASE_WEB_VAPID_KEY=${FIREBASE_WEB_VAPID_KEY}

RUN envsubst '${FIREBASE_WEB_API_KEY} ${FIREBASE_WEB_AUTH_DOMAIN} ${FIREBASE_WEB_PROJECT_ID} ${FIREBASE_WEB_STORAGE_BUCKET} ${FIREBASE_WEB_MESSAGING_SENDER_ID} ${FIREBASE_WEB_APP_ID}' \
    < web/firebase-messaging-sw.js > build/web/firebase-messaging-sw.js

FROM nginx:1.27-alpine

COPY deploy/web/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/build/web /usr/share/nginx/html
COPY --from=builder /app/web/.well-known /usr/share/nginx/html/.well-known

EXPOSE 8080
