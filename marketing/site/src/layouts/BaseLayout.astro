---
import '../styles/global.css';
import { buildCanonicalUrl, siteMeta } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  path = '/',
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0E1A" />
    <link rel="canonical" href={buildCanonicalUrl(path)} />
    <link rel="icon" type="image/png" href="/ingame-logo.png" />
    <link rel="apple-touch-icon" href="/ingame-logo.png" />
  </head>
  <body class="min-h-screen text-white">
    <slot />
  </body>
</html>
