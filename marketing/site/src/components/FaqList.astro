---
import GlassPanel from './GlassPanel.astro';
import SectionHeading from './SectionHeading.astro';

interface FaqItem {
  question: string;
  answer: string;
}

const { items } = Astro.props as { items: readonly FaqItem[] };
---

<section id="faq" class="mx-auto max-w-6xl px-6 py-16">
  <SectionHeading
    eyebrow="FAQ"
    title="A few quick answers."
    body="The marketing site keeps the story concise, but the core product positioning should still be explicit."
  />
  <div class="mt-10 grid gap-5">
    {items.map((item) => (
      <GlassPanel class="p-6">
        <h3 class="text-xl font-semibold">{item.question}</h3>
        <p class="mt-3 text-white/70">{item.answer}</p>
      </GlassPanel>
    ))}
  </div>
</section>
