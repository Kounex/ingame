---
import GlassPanel from './GlassPanel.astro';
import SectionHeading from './SectionHeading.astro';

interface PlatformItem {
  label: string;
  body: string;
}

interface PlatformData {
  heading: string;
  description: string;
  items: readonly PlatformItem[];
}

const { platforms } = Astro.props as { platforms: PlatformData };
---

<section id="platforms" class="mx-auto max-w-6xl px-6 py-16">
  <GlassPanel class="p-8">
    <SectionHeading eyebrow="Platforms" title={platforms.heading} body={platforms.description} />
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a
        class="rounded-xl bg-ig-primary px-5 py-3 text-center font-semibold text-ig-background no-underline shadow-glow"
        href="https://app.in-game.app"
      >
        Open on Web
      </a>
      <span class="rounded-xl border border-white/10 bg-white/10 px-5 py-3 text-center font-semibold text-white/80">
        App Store
      </span>
      <span class="rounded-xl border border-white/10 bg-white/10 px-5 py-3 text-center font-semibold text-white/80">
        Google Play
      </span>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {platforms.items.map((item) => (
        <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
          <h3 class="text-xl font-semibold">{item.label}</h3>
          <p class="mt-3 text-white/70">{item.body}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-white/60">
      Web gets you in immediately. Native apps are the recommended path for notification-driven coordination on mobile.
    </p>
  </GlassPanel>
</section>
