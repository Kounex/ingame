---
interface LegalLink {
  label: string;
  href: string;
}

interface FooterData {
  legalLinks: readonly LegalLink[];
}

const { footer } = Astro.props as { footer: FooterData };
---

<footer class="mx-auto max-w-6xl px-6 py-10">
  <div class="flex flex-col gap-4 border-t border-white/10 pt-6 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-white/50">InGame keeps gaming coordination focused, private, and launch-ready.</p>
    <div class="flex gap-4 text-sm text-white/70">
      {footer.legalLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
  </div>
</footer>
