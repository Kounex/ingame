---
import GlassPanel from './GlassPanel.astro';
import SectionHeading from './SectionHeading.astro';

interface FeatureItem {
  title: string;
  body: string;
}

interface WhyData {
  eyebrow: string;
  title: string;
  body: string;
}

const { why, items } = Astro.props as { why: WhyData; items: FeatureItem[] };
---

<section id="features" class="mx-auto max-w-6xl px-6 py-16">
  <SectionHeading eyebrow={why.eyebrow} title={why.title} body={why.body} />
  <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
    {items.map((item) => (
      <GlassPanel class="p-6">
        <h3 class="text-xl font-semibold">{item.title}</h3>
        <p class="mt-3 text-white/70">{item.body}</p>
      </GlassPanel>
    ))}
  </div>
</section>
