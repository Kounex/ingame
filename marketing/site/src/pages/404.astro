---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found | InGame" path="/404">
  <main class="mx-auto max-w-3xl px-6 py-24 text-center">
    <h1 class="text-4xl font-bold">Page not found</h1>
    <p class="mt-6 text-white/70">The page you requested is not available on in-game.app.</p>
    <a
      class="mt-8 inline-flex rounded-xl bg-ig-primary px-5 py-3 font-semibold text-ig-background no-underline"
      href="/"
    >
      Back to homepage
    </a>
  </main>
</BaseLayout>
